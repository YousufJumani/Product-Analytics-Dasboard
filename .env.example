# Environment Variables — saas-analytics-copilot
# Copy to .env.local and fill in values. NEVER commit .env.local

# ─── Database ───────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, or local)
DATABASE_URL="postgresql://user:password@host:5432/saas_copilot?sslmode=require"

# ─── Auth ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# GitHub OAuth (create at github.com/settings/developers)
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# ─── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# ─── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─── GitHub Integration (for repo analytics) ─────────────────
# Personal Access Token with repo:read scope
GITHUB_TOKEN="ghp_..."

# ─── App Config ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Analytics Copilot"

# ─── Caching ─────────────────────────────────────────────────
# In-process cache TTL in seconds (default: 300)
CACHE_TTL_SECONDS="300"
